# Copy to .env and fill these values locally. Never commit .env.

# Seller wallet that receives Circle Gateway nanopayments.
SELLER_ADDRESS=0xYourSellerWalletAddress

# Buyer EOA private key for signing Arc Testnet Gateway transactions and x402 payment authorizations.
# This wallet needs Arc Testnet USDC from https://faucet.circle.com/.
PRIVATE_KEY=0xYourBuyerPrivateKey

# Optional: real payment controls.
RESOURCE_PRICE_USD=0.0001
BUYER_RESOURCE_URL=http://localhost:3337/power
DEPOSIT_USDC=0

# Optional overrides.
PORT=3337
ARC_RPC_URL=https://rpc.testnet.arc.network
GATEWAY_FACILITATOR_URL=https://gateway-api-testnet.circle.com
