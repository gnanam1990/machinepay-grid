{
  "name": "machinepay-grid",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Autonomous machine-to-machine USDC nanopayment demo for Arc and Circle builder submissions.",
  "scripts": {
    "start": "npm run server",
    "dev": "python3 -m http.server 4173",
    "server": "tsx --env-file-if-exists=.env src/seller.ts",
    "buyer": "tsx --env-file-if-exists=.env src/buyer.ts",
    "pay:real": "tsx --env-file-if-exists=.env src/buyer.ts --pay",
    "arc:check": "tsx --env-file-if-exists=.env src/arc-health.ts",
    "check": "node --check app.js && tsc --noEmit && node scripts/check.mjs",
    "check:js": "node --check app.js",
    "check:repo": "node scripts/check.mjs",
    "check:types": "tsc --noEmit"
  },
  "keywords": [
    "arc",
    "circle",
    "usdc",
    "nanopayments",
    "agents",
    "machine-commerce"
  ],
  "license": "MIT",
  "dependencies": {
    "@circle-fin/x402-batching": "^3.0.4",
    "@x402/core": "^2.13.0",
    "@x402/evm": "^2.13.0",
    "express": "^5.2.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "viem": "^2.50.4"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1"
  }
}
